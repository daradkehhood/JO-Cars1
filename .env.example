# ===== Database =====
DATABASE_URL="postgresql://user:password@localhost:5432/jo_cars?schema=public"

# ===== Authentication =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ===== Cloudinary (Image Storage) =====
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ===== Google Maps =====
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"

# ===== OpenAI (AI Features) =====
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# ===== Email (SMTP) =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@jocars.com"

# ===== App Configuration =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JO Cars"
NEXT_PUBLIC_APP_DESCRIPTION="أفضل منصة أردنية لبيع وشراء السيارات"
NEXT_PUBLIC_CONTACT_EMAIL="info@jocars.com"
NEXT_PUBLIC_CONTACT_PHONE="+962 6 500 0000"

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===== Storage =====
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# ===== 3D Model & AR =====
NEXT_PUBLIC_MODEL_VIEWER_API_KEY="your-model-viewer-key"

# ===== Feature Flags =====
ENABLE_AI_FEATURES=true
ENABLE_3D_MODELS=true
ENABLE_AR_VIEWER=true
ENABLE_SMART_SEARCH=true
ENABLE_DAMAGE_DETECTION=true

# ===== Security =====
CSRF_SECRET="your-csrf-secret-change-in-production"
GEO_RESTRICT_JORDAN=false
ADMIN_EMAIL="admin@jocars.com"
ADMIN_PASSWORD="generate-a-strong-password"
